@using LostAndFound.Models.Enums
@model LostAndFound.Models.ViewModels.Holding.StoredItemsViewModel
@{
    ViewData["Title"] = "Đồ đã tiếp nhận";

    string BadgeClass(FoundItemStatus s) => s switch
    {
        FoundItemStatus.Open => "bg-success",
        FoundItemStatus.ClaimAccepted => "bg-info text-dark",
        FoundItemStatus.Returned => "bg-secondary",
        FoundItemStatus.Unclaimed => "bg-warning text-dark",
        FoundItemStatus.Disposed => "bg-dark",
        _ => "bg-light text-dark"
    };
}

<div class="container mt-4 mb-5">
    <div class="mb-3">
        <h3 class="fw-bold mb-1 text-dark">Đồ ký gửi</h3>
        <p class="text-muted mb-0">Các món đã tiếp nhận vào kho: trạng thái, nơi cất, ai đã nhận. Sửa nơi cất khi chuyển đồ.</p>
    </div>

    <partial name="_HoldingTabs" />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    <form method="get" asp-action="Stored" class="d-flex gap-2 align-items-center mb-3">
        <label class="text-muted small mb-0">Lọc trạng thái:</label>
        <select name="status" class="form-select form-select-sm" style="width: auto;" onchange="this.form.submit()">
            <option value="">Tất cả</option>
            <option value="1" selected="@(Model.StatusFilter == FoundItemStatus.Open)">Đang mở</option>
            <option value="2" selected="@(Model.StatusFilter == FoundItemStatus.ClaimAccepted)">Đã duyệt nhận</option>
            <option value="3" selected="@(Model.StatusFilter == FoundItemStatus.Returned)">Đã trả</option>
            <option value="4" selected="@(Model.StatusFilter == FoundItemStatus.Unclaimed)">Chưa có người nhận</option>
            <option value="5" selected="@(Model.StatusFilter == FoundItemStatus.Disposed)">Đã thanh lý</option>
        </select>
    </form>

    @if (!Model.Items.Any())
    {
        <div class="card border-0 shadow-sm" style="border-radius: 8px;">
            <div class="card-body text-center py-5">
                <h5 class="fw-bold text-dark">Chưa có đồ nào trong kho</h5>
                <p class="text-muted mb-0">Món ký gửi sau khi được "Tiếp nhận" sẽ xuất hiện ở đây.</p>
            </div>
        </div>
    }
    else
    {
        <div class="text-muted small mb-2">@Model.Items.Count món</div>
        <div class="table-responsive">
            <table class="table align-middle" style="border-top: 1px solid #e5e7eb;">
                <thead>
                    <tr class="text-muted" style="font-size: 0.9rem;">
                        <th class="fw-normal border-0 border-bottom pb-3">Tiêu đề</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Trạng thái</th>
                        <th class="fw-normal border-0 border-bottom pb-3" style="min-width: 240px;">Nơi cất</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Người tiếp nhận</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Người đăng</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Ngày đăng</th>
                    </tr>
                </thead>
                <tbody style="font-size: 0.95rem;">
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="py-3 border-bottom fw-medium text-dark">@item.Title</td>
                            <td class="py-3 border-bottom">
                                <span class="badge @BadgeClass(item.Status)" style="border-radius: 4px;">@item.StatusText</span>
                            </td>
                            <td class="py-3 border-bottom">
                                <form asp-action="UpdateStorage" method="post" class="d-flex gap-2 align-items-center">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="status" value="@((int?)Model.StatusFilter)" />
                                    <input type="text" name="storageLocation" value="@item.StorageLocation"
                                           class="form-control form-control-sm" maxlength="200" required style="min-width: 140px;" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary text-nowrap">Lưu</button>
                                </form>
                            </td>
                            <td class="py-3 border-bottom">@item.CustodianName</td>
                            <td class="py-3 border-bottom">@item.ReporterName</td>
                            <td class="py-3 border-bottom text-muted" style="font-size: 0.9rem;">@AppTime.ToLocal(item.CreatedAt).ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
