@{
    var current = ViewContext.RouteData.Values["action"]?.ToString();
}
<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link @(current == "Index" ? "active" : "")" asp-controller="Holding" asp-action="Index">Chờ tiếp nhận</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(current == "Stored" ? "active" : "")" asp-controller="Holding" asp-action="Stored">Đã tiếp nhận</a>
    </li>
</ul>
