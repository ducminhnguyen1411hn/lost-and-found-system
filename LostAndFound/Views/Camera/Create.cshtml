@model LostAndFound.Models.ViewModels.Camera.CameraRequestCreateViewModel
@{
    ViewData["Title"] = "Xin show camera";
    var nowMax = AppTime.LocalNow.ToString("yyyy-MM-ddTHH:mm");
}

<h1 class="h4 mb-1">Xin show camera</h1>
<p class="text-muted">Nhờ nhân viên xem lại camera một khu vực trong khoảng thời gian để tìm món đồ của bạn.</p>

<form asp-action="Create" method="post" class="row g-3" style="max-width: 640px;">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-12">
        <label asp-for="LocationId" class="form-label"></label>
        <select asp-for="LocationId" asp-items="Model.Locations" class="form-select">
            <option value="">-- Chọn khu vực --</option>
        </select>
        <span asp-validation-for="LocationId" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="FromTime" class="form-label"></label>
        <input asp-for="FromTime" type="datetime-local" max="@nowMax" class="form-control" />
        <span asp-validation-for="FromTime" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="ToTime" class="form-label"></label>
        <input asp-for="ToTime" type="datetime-local" max="@nowMax" class="form-control" />
        <span asp-validation-for="ToTime" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="ItemDescription" class="form-label"></label>
        <textarea asp-for="ItemDescription" class="form-control" rows="3"
                  placeholder="VD: balo đen, có móc khoá hình gấu; đánh rơi khoảng giờ ra chơi."></textarea>
        <span asp-validation-for="ItemDescription" class="text-danger"></span>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Gửi yêu cầu</button>
        <a asp-action="Mine" class="btn btn-link">Yêu cầu của tôi</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
