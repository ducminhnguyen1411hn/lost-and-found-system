@model ClaimDetailViewModel
@using LostAndFound.Models.Enums
@{
    ViewData["Title"] = "Yêu cầu nhận lại — " + Model.ItemTitle;
    var badge = Model.Status switch
    {
        ClaimStatus.Pending => "<span class='badge bg-warning text-dark'>Đang chờ</span>",
        ClaimStatus.Accepted => "<span class='badge bg-success'>Được chấp nhận</span>",
        _ => "<span class='badge bg-secondary'>Bị từ chối</span>"
    };
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-info">@TempData["SuccessMessage"]</div>
}

<a asp-controller="FoundItems" asp-action="Details" asp-route-id="@Model.FoundItemId" class="text-decoration-none">&larr; Về món đồ</a>

<div class="d-flex align-items-center gap-2 mt-2 mb-3">
    <h1 class="h4 mb-0">@Model.ItemTitle</h1>
    @Html.Raw(badge)
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header bg-light">Nội dung xác minh</div>
            <div class="card-body">
                <div class="small text-muted mb-1">
                    @Model.ClaimantName · @AppTime.ToLocal(Model.CreatedAt).ToString("dd/MM/yyyy HH:mm")
                </div>
                <p class="mb-2">@Model.VerificationDetails</p>
                @if (Model.EvidenceImagePaths.Count > 0)
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var url in Model.EvidenceImagePaths)
                        {
                            <a href="@url" target="_blank">
                                <img src="@url" class="rounded border object-fit-cover" style="height:80px;width:80px;" alt="bằng chứng" />
                            </a>
                        }
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ContactPhone) || !string.IsNullOrWhiteSpace(Model.ContactEmail))
                {
                    <div class="mt-3">
                        <div class="small text-uppercase text-muted fw-semibold mb-1">Liên hệ</div>
                        @if (!string.IsNullOrWhiteSpace(Model.ContactPhone))
                        {
                            <div>📞 <a href="tel:@Model.ContactPhone">@Model.ContactPhone</a></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.ContactEmail))
                        {
                            <div>✉️ <a href="mailto:@Model.ContactEmail">@Model.ContactEmail</a></div>
                        }
                        @if (!Model.ViewerIsHolder)
                        {
                            <div class="form-text">Chỉ người đang giữ món đồ nhìn thấy phần này.</div>
                        }
                    </div>
                }
                @if (Model.Status == ClaimStatus.Rejected && !string.IsNullOrWhiteSpace(Model.RejectReason))
                {
                    <div class="alert alert-secondary mt-3 mb-0 small">Lý do từ chối: @Model.RejectReason</div>
                }
            </div>
        </div>

        @if (Model.CanAccept || Model.CanReject)
        {
            <div class="card border-primary mt-3">
                <div class="card-header bg-light">Quyết định</div>
                <div class="card-body d-flex flex-column gap-2">
                    @if (Model.CanAccept)
                    {
                        <form asp-action="Accept" method="post"
                              onsubmit="return confirm('Chấp nhận yêu cầu này? Các yêu cầu khác trên món đồ sẽ tự động bị từ chối.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="claimId" value="@Model.ClaimId" />
                            <input type="hidden" name="foundItemId" value="@Model.FoundItemId" />
                            <button type="submit" class="btn btn-success btn-sm">Chấp nhận</button>
                        </form>
                    }
                    @if (Model.CanReject)
                    {
                        <form asp-action="Reject" method="post" class="d-flex gap-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ClaimId" value="@Model.ClaimId" />
                            <input type="hidden" name="foundItemId" value="@Model.FoundItemId" />
                            <input type="text" name="RejectReason" class="form-control form-control-sm" placeholder="Lý do từ chối" required />
                            <button type="submit" class="btn btn-outline-danger btn-sm">Từ chối</button>
                        </form>
                    }
                    <div class="form-text mb-0">Chưa chắc? Hỏi thêm ở khung trao đổi bên cạnh trước khi quyết định.</div>
                </div>
            </div>
        }

        @* Same partial as the item page — one source of truth for the handover UI. *@
        @if (Model.Handover is not null)
        {
            <partial name="_HandoverPanel" model="Model.Handover" />
        }
    </div>

    <div class="col-lg-7">
        <div class="card">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <span>Trao đổi</span>
                <span class="small text-muted">Chỉ bạn và bên kia đọc được</span>
            </div>
            <div class="card-body d-flex flex-column gap-2" style="max-height:420px; overflow-y:auto;">
                @if (Model.Messages.Count == 0)
                {
                    <p class="text-muted small mb-0">
                        Chưa có tin nhắn. Người giữ có thể hỏi một đặc điểm mà chỉ chủ nhân biết
                        (ví dụ: "trong ngăn nhỏ có gì?") trước khi quyết định.
                    </p>
                }
                else
                {
                    @foreach (var m in Model.Messages)
                    {
                        <div class="d-flex @(m.IsMine ? "justify-content-end" : "justify-content-start")">
                            <div class="rounded px-3 py-2 @(m.IsMine ? "bg-primary text-white" : "bg-light border")" style="max-width:80%;">
                                <div class="small @(m.IsMine ? "text-white-50" : "text-muted")">
                                    @m.SenderName · @AppTime.ToLocal(m.CreatedAt).ToString("dd/MM HH:mm")
                                </div>
                                <div style="white-space:pre-wrap;">@m.Body</div>
                            </div>
                        </div>
                    }
                }
            </div>
            @if (Model.CanPostMessage)
            {
                <div class="card-footer bg-white">
                    <form asp-action="PostMessage" asp-route-id="@Model.ClaimId" method="post" class="d-flex gap-2">
                        @Html.AntiForgeryToken()
                        <input type="text" name="newMessage" class="form-control" maxlength="2000"
                               placeholder="Nhắn cho bên kia…" required />
                        <button type="submit" class="btn btn-primary">Gửi</button>
                    </form>
                    <div class="form-text">Đừng đăng số điện thoại nếu bạn chưa muốn — cứ trao đổi ở đây.</div>
                </div>
            }
            else
            {
                <div class="card-footer bg-light small text-muted">Yêu cầu đã đóng — không gửi tin nhắn được nữa.</div>
            }
        </div>
    </div>
</div>
