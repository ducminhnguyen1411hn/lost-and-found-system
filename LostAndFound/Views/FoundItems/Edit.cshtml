@model FoundItemEditViewModel
@{
    ViewData["Title"] = "Sửa bài đăng";
    var nowMax = AppTime.LocalNow.ToString("yyyy-MM-ddTHH:mm");
}

<h1 class="h3 mb-3">Sửa bài đăng</h1>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="row">
        <div class="col-md-8">
            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <div class="form-text"><strong>Đừng</strong> viết đặc điểm bí mật trong mô tả công khai.</div>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-sm-6 mb-3">
                    <label asp-for="CategoryId" class="form-label"></label>
                    <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
                <div class="col-sm-6 mb-3">
                    <label asp-for="LocationId" class="form-label"></label>
                    <select asp-for="LocationId" asp-items="Model.Locations" class="form-select">
                        <option value="">-- Chọn nơi nhặt --</option>
                    </select>
                    <span asp-validation-for="LocationId" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="FoundAt" class="form-label"></label>
                <input asp-for="FoundAt" type="datetime-local" max="@nowMax" class="form-control" />
                <span asp-validation-for="FoundAt" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TagsRaw" class="form-label"></label>
                <partial name="_TagInput" model="@Model.TagsRaw" />
            </div>
        </div>

        <div class="col-md-4">
            <div class="mb-3">
                <label class="form-label d-block">Hình thức giữ</label>
                <span class="badge bg-light text-dark border">
                    @(Model.HoldingType == HoldingType.Custodial ? "Ký gửi cho Staff" : "Người nhặt tự giữ")
                </span>
                <div class="form-text">Không đổi được sau khi đăng.</div>
            </div>

            <div class="mb-3">
                <label class="form-label d-block">Ảnh hiện tại</label>
                @if (Model.ExistingImages.Count == 0)
                {
                    <div class="text-muted small mb-2">Chưa có ảnh</div>
                }
                else
                {
                    <div class="row row-cols-3 g-2 mb-1" id="existingImages">
                        @foreach (var img in Model.ExistingImages)
                        {
                            <div class="col">
                                <div class="position-relative" data-img>
                                    <img src="@img.Url" class="img-fluid rounded w-100" style="height:70px;object-fit:cover;" alt="ảnh" data-thumb />
                                    <input type="checkbox" name="RemoveImageIds" value="@img.Id" class="d-none" data-remove-flag />
                                    <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1 py-0 px-1 lh-1"
                                            data-remove-btn title="Xoá ảnh này">&times;</button>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="form-text">Bấm × để đánh dấu xoá (bấm lại để hoàn tác). Ảnh bìa = ảnh đầu tiên còn lại. Tối đa 7 ảnh.</div>
                }
            </div>
            <div class="mb-3">
                <label asp-for="NewImages" class="form-label"></label>
                <input asp-for="NewImages" type="file" accept="image/*" multiple class="form-control" />
                <span asp-validation-for="NewImages" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PrivateMarks" class="form-label"></label>
                <textarea asp-for="PrivateMarks" class="form-control" rows="3"></textarea>
                <div class="form-text">Không hiển thị công khai; người tới nhận không thấy.</div>
                <span asp-validation-for="PrivateMarks" class="text-danger"></span>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Huỷ</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Toggle "remove" for each existing image via the × button (no checkbox needed on screen).
        document.querySelectorAll('#existingImages [data-img]').forEach(function (box) {
            var flag = box.querySelector('[data-remove-flag]');
            var btn = box.querySelector('[data-remove-btn]');
            var thumb = box.querySelector('[data-thumb]');
            btn.addEventListener('click', function () {
                flag.checked = !flag.checked;
                thumb.style.opacity = flag.checked ? '0.35' : '1';
                btn.classList.toggle('btn-danger', !flag.checked);
                btn.classList.toggle('btn-secondary', flag.checked);
                btn.innerHTML = flag.checked ? '&#8635;' : '&times;'; // ↻ undo / ×
                btn.title = flag.checked ? 'Hoàn tác' : 'Xoá ảnh này';
            });
        });
    </script>
}
