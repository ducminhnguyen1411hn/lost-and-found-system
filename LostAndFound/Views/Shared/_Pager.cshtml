@model FoundItemSearchViewModel
@{
    var r = Model.Results;
}

@if (r.TotalPages > 1)
{
    <nav aria-label="Phân trang">
        <ul class="pagination justify-content-center">
            <li class="page-item @(r.HasPrevious ? "" : "disabled")">
                <a class="page-link"
                   asp-controller="FoundItems" asp-action="Index"
                   asp-route-Keyword="@Model.Keyword" asp-route-CategoryId="@Model.CategoryId"
                   asp-route-LocationId="@Model.LocationId" asp-route-Tag="@Model.Tag"
                   asp-route-FoundFrom="@(Model.FoundFrom?.ToString("yyyy-MM-dd"))" asp-route-FoundTo="@(Model.FoundTo?.ToString("yyyy-MM-dd"))"
                   asp-route-PageSize="@Model.PageSize" asp-route-Page="@(r.Page - 1)">«</a>
            </li>
            @for (int p = 1; p <= r.TotalPages; p++)
            {
                <li class="page-item @(p == r.Page ? "active" : "")">
                    <a class="page-link"
                       asp-controller="FoundItems" asp-action="Index"
                       asp-route-Keyword="@Model.Keyword" asp-route-CategoryId="@Model.CategoryId"
                       asp-route-LocationId="@Model.LocationId" asp-route-Tag="@Model.Tag"
                       asp-route-PageSize="@Model.PageSize" asp-route-Page="@p">@p</a>
                </li>
            }
            <li class="page-item @(r.HasNext ? "" : "disabled")">
                <a class="page-link"
                   asp-controller="FoundItems" asp-action="Index"
                   asp-route-Keyword="@Model.Keyword" asp-route-CategoryId="@Model.CategoryId"
                   asp-route-LocationId="@Model.LocationId" asp-route-Tag="@Model.Tag"
                   asp-route-FoundFrom="@(Model.FoundFrom?.ToString("yyyy-MM-dd"))" asp-route-FoundTo="@(Model.FoundTo?.ToString("yyyy-MM-dd"))"
                   asp-route-PageSize="@Model.PageSize" asp-route-Page="@(r.Page + 1)">»</a>
            </li>
        </ul>
    </nav>
}
