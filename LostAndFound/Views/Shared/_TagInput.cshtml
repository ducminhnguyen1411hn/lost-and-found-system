@*
    Reusable tag input (FR-TAG). Convention: the owning ViewModel exposes a string property named
    `TagsRaw`; this partial binds to it by name. Comma-separated; a small script renders a live chip
    preview but the text field stays the source of truth (works fine without JS). Autocomplete = FR-TAG-04.
    Usage: <partial name="_TagInput" model="@Model.TagsRaw" />
*@
@model string

<style>
    .autocomplete-dropdown {
        position: absolute;
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        z-index: 1000;
        max-height: 200px;
        overflow-y: auto;
        min-width: 100%;
        display: none;
    }
    .autocomplete-dropdown div {
        padding: 0.5rem;
        cursor: pointer;
    }
    .autocomplete-dropdown div:hover {
        background-color: #f8f9fa;
    }
</style>

<div data-tag-input style="position: relative;">
    <input type="text" name="TagsRaw" id="TagsRaw" value="@Model" class="form-control"
           placeholder="Ví dụ: ví da, thẻ sinh viên, chìa khoá" autocomplete="off" />
    <div class="form-text">Phân tách các thẻ bằng dấu phẩy. Thẻ giúp người mất đồ tìm ra & để hệ thống so khớp.</div>
    <div class="mt-2" data-tag-preview></div>
    <div class="autocomplete-dropdown"></div>
</div>

<script>
    (function () {
        var wrap = document.currentScript.previousElementSibling;
        var input = wrap.querySelector('#TagsRaw');
        var preview = wrap.querySelector('[data-tag-preview]');
        var dropdown = wrap.querySelector('.autocomplete-dropdown');
        var debounceTimer;

        function render() {
            preview.innerHTML = '';
            input.value.split(',').map(function (s) { return s.trim(); }).filter(Boolean)
                .forEach(function (t) {
                    var b = document.createElement('span');
                    b.className = 'badge bg-secondary me-1';
                    b.textContent = t;
                    preview.appendChild(b);
                });
        }

        function getCurrentTag() {
            var cursorPos = input.selectionStart;
            var textBefore = input.value.substring(0, cursorPos);
            var lastComma = textBefore.lastIndexOf(',');
            return textBefore.substring(lastComma + 1).trim();
        }

        function showSuggestions(suggestions) {
            dropdown.innerHTML = '';
            if (suggestions.length === 0) {
                dropdown.style.display = 'none';
                return;
            }

            suggestions.forEach(function (s) {
                var item = document.createElement('div');
                item.textContent = s;
                item.addEventListener('click', function () {
                    var cursorPos = input.selectionStart;
                    var textBefore = input.value.substring(0, cursorPos);
                    var lastComma = textBefore.lastIndexOf(',');
                    var textAfter = input.value.substring(cursorPos);

                    // Replace the current tag with the selected suggestion
                    var newValue = input.value.substring(0, lastComma + 1) + ' ' + s + ', ' + textAfter;
                    input.value = newValue.trim();
                    dropdown.style.display = 'none';
                    render();
                    input.focus();
                });
                dropdown.appendChild(item);
            });

            dropdown.style.display = 'block';
        }

        function hideDropdown() {
            dropdown.style.display = 'none';
        }

        input.addEventListener('input', function () {
            render();
            clearTimeout(debounceTimer);

            var currentTag = getCurrentTag();
            if (currentTag.length < 2) {
                hideDropdown();
                return;
            }

            debounceTimer = setTimeout(function () {
                fetch('/Tags/Suggest?q=' + encodeURIComponent(currentTag))
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        showSuggestions(data);
                    })
                    .catch(function () {
                        hideDropdown();
                    });
            }, 300);
        });

        input.addEventListener('blur', function () {
            setTimeout(hideDropdown, 200);
        });

        input.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                hideDropdown();
            }
        });

        render();
    })();
</script>
