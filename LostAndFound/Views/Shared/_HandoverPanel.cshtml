@model HandoverPanelViewModel

<div class="card border-success mt-3">
    <div class="card-header bg-light">Bàn giao 2 chiều</div>
    <div class="card-body">
        <p class="text-center text-muted small mb-3">
            Cả hai bên phải xác nhận thì món đồ mới chuyển sang <strong>Đã trả</strong>.
        </p>

        <div class="row g-3 justify-content-center">
            @* --- Holder side --- *@
            <div class="col-md-5">
                <div class="card h-100 @(Model.HolderConfirmed ? "border-success" : "")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <span class="fw-semibold">Người giữ</span>
                            <span class="badge @(Model.HolderConfirmed ? "bg-success" : "bg-warning text-dark")">
                                @(Model.HolderConfirmed ? "Đã xong" : "Đang chờ")
                            </span>
                        </div>
                        <div class="mb-1">@(Model.HolderConfirmed ? "☑" : "☐") Đã bàn giao món đồ</div>
                        <div class="small text-muted">
                            @Model.HolderName@(Model.ViewerIsHolder ? " (bạn)" : "")
                            @* Razor compiles the whole view into ONE method, so pattern variables here share
                               a single scope — the two sides must not both call theirs `at` (CS0128). *@
                            @if (Model.HolderConfirmedAt is DateTime holderAt)
                            {
                                @* Stored UTC — always render through AppTime, never the raw value. *@
                                <span>· @AppTime.ToLocal(holderAt).ToString("dd/MM HH:mm")</span>
                            }
                        </div>
                        @if (Model.ViewerIsHolder && !Model.HolderConfirmed)
                        {
                            <form asp-controller="Claims" asp-action="ConfirmHandover" asp-route-foundItemId="@Model.FoundItemId" method="post" class="mt-3">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success btn-sm w-100">Xác nhận đã bàn giao</button>
                            </form>
                        }
                    </div>
                </div>
            </div>

            @* --- Claimant side --- *@
            <div class="col-md-5">
                <div class="card h-100 @(Model.ClaimantConfirmed ? "border-success" : "")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <span class="fw-semibold">Người nhận</span>
                            <span class="badge @(Model.ClaimantConfirmed ? "bg-success" : "bg-warning text-dark")">
                                @(Model.ClaimantConfirmed ? "Đã xong" : "Đang chờ")
                            </span>
                        </div>
                        <div class="mb-1">@(Model.ClaimantConfirmed ? "☑" : "☐") Đã nhận được đồ</div>
                        <div class="small text-muted">
                            @Model.ClaimantName@(Model.ViewerIsClaimant ? " (bạn)" : "")
                            @if (Model.ClaimantConfirmedAt is DateTime claimantAt)
                            {
                                <span>· @AppTime.ToLocal(claimantAt).ToString("dd/MM HH:mm")</span>
                            }
                        </div>
                        @if (Model.ViewerIsClaimant && !Model.ClaimantConfirmed)
                        {
                            <form asp-controller="Claims" asp-action="ConfirmReceived" asp-route-foundItemId="@Model.FoundItemId" method="post" class="mt-3">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success btn-sm w-100">Xác nhận đã nhận đồ</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* State the rule out loud — it's the whole point of FR-CLAIM-05 and it isn't obvious from two checkboxes. *@
        <div class="alert alert-info small text-center mt-3 mb-0">
            Khi <strong>cả hai</strong> cùng xác nhận → món đồ chuyển sang <strong>Đã trả</strong> và lịch sử được chốt lại.
        </div>

        @if (Model.CanCancelAcceptance)
        {
            <div class="text-center mt-3">
                <form asp-controller="Claims" asp-action="CancelAcceptance" asp-route-foundItemId="@Model.FoundItemId" method="post"
                      onsubmit="return confirm('Huỷ chấp nhận và mở lại yêu cầu?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm">Huỷ chấp nhận</button>
                </form>
            </div>
        }
    </div>
</div>
