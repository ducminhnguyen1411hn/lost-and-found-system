@model ClaimCreateViewModel

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<input type="hidden" asp-for="FoundItemId" />

<div class="mb-3">
    <label asp-for="VerificationDetails" class="form-label"></label>
    <textarea asp-for="VerificationDetails" class="form-control" rows="5"
              placeholder="VD: mặt sau có vết xước, sticker hình mèo ở góc, số serial ...&#10;Ghi chi tiết chỉ chủ nhân mới biết."></textarea>
    <span asp-validation-for="VerificationDetails" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="EvidenceImages" class="form-label"></label>
    <input asp-for="EvidenceImages" type="file" class="form-control" multiple accept="image/*" />
    <div class="form-text">Tối đa 5 ảnh. Ví dụ: hoá đơn, ảnh chụp cùng món đồ, ảnh số serial.</div>
    <span asp-validation-for="EvidenceImages" class="text-danger"></span>
</div>
