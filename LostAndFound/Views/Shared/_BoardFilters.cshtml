@model BoardSearchViewModel
@{

    var boardAction = (string?)ViewData["BoardAction"] ?? "Index";
}

<form asp-controller="Items" asp-action="@boardAction" method="get" class="d-flex flex-column gap-3">
    <div>
        <label class="form-label small text-uppercase text-muted fw-semibold">Loại</label>
        <div class="form-check">
            <input class="form-check-input" type="radio" name="Kind" id="kind-all" value="" checked="@(!Model.Kind.HasValue)" />
            <label class="form-check-label" for="kind-all">Tất cả</label>
        </div>
        <div class="form-check">
            <input class="form-check-input" type="radio" name="Kind" id="kind-found" value="Found" checked="@(Model.Kind == ItemKind.Found)" />
            <label class="form-check-label" for="kind-found">Đồ nhặt được</label>
        </div>
        <div class="form-check">
            <input class="form-check-input" type="radio" name="Kind" id="kind-lost" value="Lost" checked="@(Model.Kind == ItemKind.Lost)" />
            <label class="form-check-label" for="kind-lost">Đồ bị mất</label>
        </div>
    </div>

    <hr class="my-0" />

    <div>
        <label asp-for="Keyword" class="form-label small text-uppercase text-muted fw-semibold">Từ khoá</label>
        <input asp-for="Keyword" class="form-control form-control-sm" placeholder="Tiêu đề / mô tả…" />
    </div>
    <div>
        <label asp-for="CategoryId" class="form-label small text-uppercase text-muted fw-semibold">Danh mục</label>
        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select form-select-sm">
            <option value="">-- Tất cả --</option>
        </select>
    </div>
    <div>
        <label asp-for="LocationId" class="form-label small text-uppercase text-muted fw-semibold">Nơi</label>
        <select asp-for="LocationId" asp-items="Model.Locations" class="form-select form-select-sm">
            <option value="">-- Tất cả --</option>
        </select>
    </div>
    <div>
        <label asp-for="Tag" class="form-label small text-uppercase text-muted fw-semibold">Thẻ</label>
        <input asp-for="Tag" class="form-control form-control-sm" placeholder="thẻ…" />
    </div>
    <div>
        <label class="form-label small text-uppercase text-muted fw-semibold">Khoảng thời gian</label>
        <div class="d-flex flex-column gap-2">
            <input asp-for="From" type="datetime-local" class="form-control form-control-sm" />
            <input asp-for="To" type="datetime-local" class="form-control form-control-sm" />
        </div>
        <div class="form-text">Bỏ trống = không giới hạn.</div>
        <span asp-validation-for="From" class="text-danger small"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary btn-sm flex-fill">Tìm kiếm</button>
        <a asp-controller="Items" asp-action="@boardAction" class="btn btn-outline-secondary btn-sm">Xoá lọc</a>
    </div>
</form>
