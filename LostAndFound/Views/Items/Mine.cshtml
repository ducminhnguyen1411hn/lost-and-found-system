@model BoardSearchViewModel
@{
    ViewData["Title"] = "Bài đăng của tôi";
    ViewData["BoardAction"] = "Mine";
    ViewData["BoardHeading"] = "Bài đăng của tôi";
    ViewData["BoardEmpty"] = "Bạn chưa có bài đăng nào khớp bộ lọc.";
    ViewData["ShowKindPill"] = !Model.Kind.HasValue;
    ViewData["ShowStatus"] = true;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<p class="text-muted small">
    Đây là nơi lưu trữ toàn bộ bài đăng của bạn.
</p>

<partial name="_BoardShell" model="Model" />
