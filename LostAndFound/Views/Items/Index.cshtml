@model BoardSearchViewModel
@{
    ViewData["Title"] = "Bảng đồ";
    ViewData["BoardAction"] = "Index";
    ViewData["BoardHeading"] = "Bảng đồ";
    ViewData["ShowKindPill"] = !Model.Kind.HasValue;
    ViewData["ShowStatus"] = false;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<partial name="_BoardShell" model="Model" />
