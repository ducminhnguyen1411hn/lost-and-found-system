@model List<LostAndFound.Models.ViewModels.Admin.UserRolesViewModel>
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container mt-4 mb-5">
    <h3 class="fw-bold mb-1 text-dark">Quản lý người dùng</h3>
    <p class="text-muted mb-4">Tất cả tài khoản đã đăng ký và vai trò được gán.</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 border-0" role="alert" style="background-color: #dcfce7; color: #166534; border-radius: 6px;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table align-middle" style="border-top: 1px solid #e5e7eb;">
            <thead>
                <tr class="text-muted" style="font-size: 0.9rem;">
                    <th class="fw-normal border-0 border-bottom pb-3">Email</th>
                    <th class="fw-normal border-0 border-bottom pb-3">Họ tên</th>
                    <th class="fw-normal border-0 border-bottom pb-3">Vai trò</th>
                    <th class="fw-normal border-0 border-bottom pb-3">Chặn</th>
                    <th class="fw-normal border-0 border-bottom pb-3"></th>
                </tr>
            </thead>
            <tbody style="font-size: 0.95rem;">
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="py-3 border-bottom">@user.Email</td>
                        <td class="py-3 border-bottom fw-medium text-dark">@user.FullName</td>
                        <td class="py-3 border-bottom">
                            @if (!user.Roles.Any())
                            {
                                <span class="text-muted small italic">Không có vai trò</span>
                            }
                            @foreach (var role in user.Roles)
                            {
                                string bgColor = role == "Admin" ? "#ffe4e6" : (role == "Staff" ? "#f3e8ff" : (role == "Member" ? "#e0f2fe" : "#f3f4f6"));
                                string textColor = role == "Admin" ? "#e11d48" : (role == "Staff" ? "#9333ea" : (role == "Member" ? "#0369a1" : "#374151"));

                                <span class="badge me-1" style="background-color: @bgColor; color: @textColor; font-weight: 600; padding: 6px 10px; border-radius: 4px;">@role</span>
                            }
                        </td>
                        <td class="py-3 border-bottom">
                            @if (user.IsBlocked)
                            {
                                <span class="badge bg-danger" style="border-radius: 4px;">Toàn bộ</span>
                            }
                            else if (user.IsPostingBlocked)
                            {
                                <span class="badge bg-warning" style="border-radius: 4px;">Đăng bài</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="py-3 border-bottom text-end">
                            <a asp-action="Edit" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-primary px-3" style="border-radius: 6px; font-weight: 500;">Sửa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>