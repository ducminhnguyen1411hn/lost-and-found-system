@model LostAndFound.Models.EditUserRolesViewModel
@{
    ViewData["Title"] = "Edit user roles";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-8 col-lg-6">
            <h3 class="fw-bold mb-1 text-dark">Edit user roles</h3>
            <p class="text-muted mb-4">@Model.FullName — @Model.Email</p>

            <form asp-action="Edit" method="post">
                @* Lưu trữ ngầm ID người dùng để controller nhận biết *@
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="FullName" />

                @* Hiển thị bảng thông báo lỗi từ Chốt chặn bảo mật nếu có *@
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 p-2 bg-danger-subtle rounded" style="border-left: 4px solid #dc3545;"></div>

                <div class="card shadow-sm mb-4" style="border: 1px solid #e5e7eb; border-radius: 8px;">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3 text-dark">Roles</h6>

                        @* Vòng lặp for tối ưu cho Model Binding danh sách *@
                        @for (int i = 0; i < Model.Roles.Count; i++)
                        {
                            <div class="form-check mb-2">
                                <input type="hidden" asp-for="Roles[i].RoleName" />
                                <input class="form-check-input" type="checkbox" asp-for="Roles[i].IsSelected" id="role_@i" />
                                <label class="form-check-label text-dark user-select-none" for="role_@i">
                                    @Model.Roles[i].RoleName
                                </label>
                            </div>
                        }

                        <p class="small text-muted mb-0 mt-4" style="font-size: 0.85rem; border-top: 1px dashed #e5e7eb; padding-top: 12px;">
                            <i class="bi bi-shield-lock-fill me-1"></i>Guards: can't remove your own Admin role or the last remaining Admin; role changes are audited.
                        </p>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 py-2" style="background-color: #2563eb; border: none; border-radius: 6px; font-weight: 500;">Save changes</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 6px; border-color: #d1d5db; color: #374151; font-weight: 500;">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}