@model LostAndFound.Models.ViewModels.Admin.DashboardViewModel
@{
    ViewData["Title"] = "Bảng điều khiển quản trị";
}

<div class="container mt-4 mb-5">
    <h3 class="fw-bold mb-1 text-dark">Dashboard Quản trị</h3>
    <p class="text-muted mb-4">Tổng quan thống kê hệ thống và hoạt động gần đây</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 border-0" role="alert" style="background-color: #dcfce7; color: #166534; border-radius: 6px;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 8px;">
                <div class="card-body">
                    <h6 class="text-muted mb-2" style="font-size: 0.85rem;">Tổng đồ nhặt được</h6>
                    <h3 class="fw-bold mb-0 text-dark">@Model.TotalFoundItems</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 8px;">
                <div class="card-body">
                    <h6 class="text-muted mb-2" style="font-size: 0.85rem;">Đã trả lại</h6>
                    <h3 class="fw-bold mb-0 text-success">@Model.ReturnedItems</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 8px;">
                <div class="card-body">
                    <h6 class="text-muted mb-2" style="font-size: 0.85rem;">Tỷ lệ trả lại</h6>
                    <h3 class="fw-bold mb-0 text-primary">@Model.ReturnRate.ToString("F1")%</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 8px;">
                <div class="card-body">
                    <h6 class="text-muted mb-2" style="font-size: 0.85rem;">Thời gian trả TB</h6>
                    <h3 class="fw-bold mb-0 text-info">@Model.AverageReturnDays.ToString("F1") ngày</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 8px;">
                <div class="card-body">
                    <h6 class="text-muted mb-3" style="font-size: 0.85rem;">Đồ chưa nhận lâu nhất</h6>
                    <h3 class="fw-bold mb-0 text-warning">@Model.LongestUnclaimedDays ngày</h3>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 8px;">
                <div class="card-body">
                    <h6 class="text-muted mb-3" style="font-size: 0.85rem;">Hành động nhanh</h6>
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-action="Categories" class="btn btn-outline-primary btn-sm" style="border-radius: 6px;">Quản lý danh mục</a>
                        <a asp-action="Locations" class="btn btn-outline-primary btn-sm" style="border-radius: 6px;">Quản lý địa điểm</a>
                        <a asp-action="Tags" class="btn btn-outline-primary btn-sm" style="border-radius: 6px;">Quản lý thẻ</a>
                        <a asp-action="Unclaimed" class="btn btn-outline-warning btn-sm" style="border-radius: 6px;">Đồ chưa nhận</a>
                        <a asp-action="AuditLog" class="btn btn-outline-secondary btn-sm" style="border-radius: 6px;">Nhật ký</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 8px;">
                <div class="card-body">
                    <h6 class="fw-bold mb-3 text-dark">Người nhặt nhiều nhất</h6>
                    @if (Model.TopFinders.Any())
                    {
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th class="border-0">Người dùng</th>
                                    <th class="border-0 text-end">Số đồ nhặt</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var finder in Model.TopFinders)
                                {
                                    <tr>
                                        <td class="border-0">@finder.FullName</td>
                                        <td class="border-0 text-end fw-bold">@finder.ItemsFound</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Không có dữ liệu</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 8px;">
                <div class="card-body">
                    <h6 class="fw-bold mb-3 text-dark">Hoạt động gần đây</h6>
                    @if (Model.RecentActivities.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th class="border-0">Hành động</th>
                                        <th class="border-0">Đối tượng</th>
                                        <th class="border-0">Người thực hiện</th>
                                        <th class="border-0">Thời gian</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var activity in Model.RecentActivities)
                                    {
                                        <tr>
                                            <td class="border-0">@activity.Action</td>
                                            <td class="border-0">@activity.EntityType #@activity.EntityId</td>
                                            <td class="border-0">@activity.ActorName</td>
                                            <td class="border-0 text-muted" style="font-size: 0.85rem;">@activity.CreatedAt.ToString("dd/MM HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Không có hoạt động gần đây</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>