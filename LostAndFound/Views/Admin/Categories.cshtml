@model List<LostAndFound.Models.ViewModels.Admin.CategoryViewModel>
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1 text-dark">Quản lý danh mục</h3>
            <p class="text-muted mb-0">Quản lý danh mục 2 cấp</p>
        </div>
        <a asp-action="CreateCategory" class="btn btn-primary" style="border-radius: 6px;">
            <i class="bi bi-plus-lg me-1"></i> Thêm danh mục
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 border-0" role="alert" style="background-color: #dcfce7; color: #166534; border-radius: 6px;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4 border-0" role="alert" style="background-color: #fee2e2; color: #991b1b; border-radius: 6px;">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table align-middle" style="border-top: 1px solid #e5e7eb;">
            <thead>
                <tr class="text-muted" style="font-size: 0.9rem;">
                    <th class="fw-normal border-0 border-bottom pb-3">Tên</th>
                    <th class="fw-normal border-0 border-bottom pb-3">Danh mục cha</th>
                    <th class="fw-normal border-0 border-bottom pb-3">Số đồ</th>
                    <th class="fw-normal border-0 border-bottom pb-3">Có danh mục con</th>
                    <th class="fw-normal border-0 border-bottom pb-3 text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody style="font-size: 0.95rem;">
                @foreach (var category in Model)
                {
                    <tr>
                        <td class="py-3 border-bottom fw-medium text-dark">
                            @if (category.Level > 0)
                            {
                                <span class="ms-3">└ @category.Name</span>
                            }
                            else
                            {
                                @category.Name
                            }
                        </td>
                        <td class="py-3 border-bottom">@(category.ParentName ?? "-")</td>
                        <td class="py-3 border-bottom">
                            <span class="badge bg-secondary" style="border-radius: 4px;">@category.ItemCount</span>
                        </td>
                        <td class="py-3 border-bottom">
                            @if (category.HasChildren)
                            {
                                <span class="badge bg-success" style="border-radius: 4px;">Có</span>
                            }
                            else
                            {
                                <span class="text-muted">Không</span>
                            }
                        </td>
                        <td class="py-3 border-bottom text-end">
                            <a asp-action="EditCategory" asp-route-id="@category.Id" class="btn btn-sm btn-outline-primary px-3 me-1" style="border-radius: 6px; font-weight: 500;">Sửa</a>
                            <form asp-action="DeleteCategory" asp-route-id="@category.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xoá danh mục này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger px-3" style="border-radius: 6px; font-weight: 500;">Xoá</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>