@model List<LostAndFound.Models.ViewModels.Admin.AuditLogViewModel>
@{
    ViewData["Title"] = "Audit Log";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1 text-dark">Audit Log</h3>
            <p class="text-muted mb-0">System activity and changes history</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4" style="border-radius: 8px;">
        <div class="card-body p-3">
            <form asp-action="AuditLog" method="get" class="row g-3">
                <div class="col-md-3">
                    <input type="text" name="EntityType" class="form-control form-control-sm" placeholder="Entity Type" style="border-radius: 6px;" value="@ViewBag.Filter?.EntityType" />
                </div>
                <div class="col-md-3">
                    <input type="text" name="Action" class="form-control form-control-sm" placeholder="Action" style="border-radius: 6px;" value="@ViewBag.Filter?.Action" />
                </div>
                <div class="col-md-2">
                    <input type="date" name="FromDate" class="form-control form-control-sm" style="border-radius: 6px;" value="@ViewBag.Filter?.FromDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2">
                    <input type="date" name="ToDate" class="form-control form-control-sm" style="border-radius: 6px;" value="@ViewBag.Filter?.ToDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary btn-sm w-100" style="border-radius: 6px;">Filter</button>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm" style="border-radius: 8px;">
            <div class="card-body text-center py-5">
                <div class="text-muted mb-3">
                    <i class="bi bi-journal-text" style="font-size: 3rem;"></i>
                </div>
                <h5 class="fw-bold text-dark">No Audit Logs Found</h5>
                <p class="text-muted">No audit logs match the current filter criteria.</p>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle" style="border-top: 1px solid #e5e7eb;">
                <thead>
                    <tr class="text-muted" style="font-size: 0.9rem;">
                        <th class="fw-normal border-0 border-bottom pb-3">Timestamp</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Actor</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Action</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Entity</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Status Change</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Detail</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Public</th>
                    </tr>
                </thead>
                <tbody style="font-size: 0.9rem;">
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="py-3 border-bottom text-muted" style="font-size: 0.85rem;">@log.CreatedAt.ToString("MM/dd/yyyy HH:mm:ss")</td>
                            <td class="py-3 border-bottom fw-medium">@log.ActorName</td>
                            <td class="py-3 border-bottom">
                                <span class="badge bg-primary" style="border-radius: 4px;">@log.Action</span>
                            </td>
                            <td class="py-3 border-bottom">
                                @log.EntityType #@log.EntityId
                            </td>
                            <td class="py-3 border-bottom">
                                @if (!string.IsNullOrEmpty(log.FromStatus) || !string.IsNullOrEmpty(log.ToStatus))
                                {
                                    <span class="small text-muted">
                                        @if (!string.IsNullOrEmpty(log.FromStatus))
                                        {
                                            <span class="text-decoration-line-through">@log.FromStatus</span>
                                        }
                                        @if (!string.IsNullOrEmpty(log.FromStatus) && !string.IsNullOrEmpty(log.ToStatus))
                                        {
                                            <span>→</span>
                                        }
                                        @if (!string.IsNullOrEmpty(log.ToStatus))
                                        {
                                            <span class="fw-bold">@log.ToStatus</span>
                                        }
                                    </span>
                                }
                            </td>
                            <td class="py-3 border-bottom">
                                @if (!string.IsNullOrEmpty(log.Detail))
                                {
                                    <span class="text-muted small" title="@log.Detail">@(log.Detail.Length > 50 ? log.Detail.Substring(0, 50) + "..." : log.Detail)</span>
                                }
                            </td>
                            <td class="py-3 border-bottom">
                                @if (log.IsPublic)
                                {
                                    <span class="badge bg-success" style="border-radius: 4px;">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary" style="border-radius: 4px;">No</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>