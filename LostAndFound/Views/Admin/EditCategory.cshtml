@model LostAndFound.Models.ViewModels.Admin.CategoryEditViewModel
@{
    ViewData["Title"] = "Edit Category";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm" style="border-radius: 8px;">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4 text-dark">Edit Category</h4>

                    <form asp-action="EditCategory" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-medium">Category Name</label>
                            <input asp-for="Name" class="form-control" style="border-radius: 6px;" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ParentId" class="form-label fw-medium">Parent Category (Optional)</label>
                            <select asp-for="ParentId" class="form-select" style="border-radius: 6px;">
                                <option value="">-- None (Root Category) --</option>
                                @if (ViewBag.ParentCategories != null)
                                {
                                    @foreach (var parent in ViewBag.ParentCategories as List<LostAndFound.Models.ViewModels.Admin.CategoryViewModel>)
                                    {
                                        // Don't show self or descendants as options
                                        if (parent.Id != Model.Id && parent.ParentId == null)
                                        {
                                            <option value="@parent.Id" selected="@(parent.Id == Model.ParentId)">@parent.Name</option>
                                        }
                                    }
                                }
                            </select>
                            <span asp-validation-for="ParentId" class="text-danger small"></span>
                            <small class="text-muted">Leave empty for a root category</small>
                        </div>

                        @if (Model.HasChildren)
                        {
                            <div class="alert alert-info border-0" style="background-color: #e0f2fe; color: #0369a1; border-radius: 6px;">
                                <small>This category has child categories. Changing the parent may affect the hierarchy.</small>
                            </div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary" style="border-radius: 6px;">Update Category</button>
                            <a asp-action="Categories" class="btn btn-outline-secondary" style="border-radius: 6px;">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}