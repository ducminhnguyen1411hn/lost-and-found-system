@model LostAndFound.Models.ViewModels.Admin.CategoryEditViewModel
@{
    ViewData["Title"] = "Sửa danh mục";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm" style="border-radius: 8px;">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4 text-dark">Sửa danh mục</h4>

                    <form asp-action="EditCategory" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-medium">Tên danh mục</label>
                            <input asp-for="Name" class="form-control" style="border-radius: 6px;" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ParentId" class="form-label fw-medium">Danh mục cha (tuỳ chọn)</label>
                            <select asp-for="ParentId" class="form-select" style="border-radius: 6px;">
                                <option value="">-- Không (danh mục gốc) --</option>
                                @if (ViewBag.ParentCategories != null)
                                {
                                    @foreach (var parent in ViewBag.ParentCategories as List<LostAndFound.Models.ViewModels.Admin.CategoryViewModel>)
                                    {

                                        if (parent.Id != Model.Id && parent.ParentId == null)
                                        {
                                            <option value="@parent.Id" selected="@(parent.Id == Model.ParentId)">@parent.Name</option>
                                        }
                                    }
                                }
                            </select>
                            <span asp-validation-for="ParentId" class="text-danger small"></span>
                            <small class="text-muted">Để trống nếu là danh mục gốc</small>
                        </div>

                        @if (Model.HasChildren)
                        {
                            <div class="alert alert-info border-0" style="background-color: #e0f2fe; color: #0369a1; border-radius: 6px;">
                                <small>Danh mục này có danh mục con. Đổi danh mục cha có thể ảnh hưởng đến cấu trúc phân cấp.</small>
                            </div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary" style="border-radius: 6px;">Cập nhật danh mục</button>
                            <a asp-action="Categories" class="btn btn-outline-secondary" style="border-radius: 6px;">Huỷ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}