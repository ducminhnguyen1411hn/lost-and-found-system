@model List<LostAndFound.Models.ViewModels.Admin.UnclaimedItemViewModel>
@{
    ViewData["Title"] = "Đồ chưa có người nhận";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1 text-dark">Đồ chưa có người nhận</h3>
            <p class="text-muted mb-1">Dưới đây là những món đồ chưa có người nhận quá 30 ngày.</p>
            <p class="text-muted mb-0">Quét để lấy được dữ liệu đồ chưa có người nhận lâu ngày.</p>
        </div>
        <form asp-action="SweepUnclaimed" method="post" class="d-inline"
              onsubmit="return confirm('Đánh dấu tất cả đồ đang mở đã quá @ViewBag.OverdueDays ngày (và không có ai đang xin nhận) là chưa có người nhận?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-primary text-nowrap">Quét đồ quá hạn (@ViewBag.OverdueDays ngày)</button>
        </form>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 border-0" role="alert" style="background-color: #dcfce7; color: #166534; border-radius: 6px;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4 border-0" role="alert" style="background-color: #fee2e2; color: #991b1b; border-radius: 6px;">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show mb-4 border-0" role="alert" style="background-color: #e0f2fe; color: #075985; border-radius: 6px;">
            @TempData["InfoMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm" style="border-radius: 8px;">
            <div class="card-body text-center py-5">
                <div class="text-muted mb-3">
                    <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                </div>
                <h5 class="fw-bold text-dark">Không có đồ chưa nhận</h5>
                <p class="text-muted">Hiện chưa có món nào ở trạng thái chưa có người nhận.</p>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle" style="border-top: 1px solid #e5e7eb;">
                <thead>
                    <tr class="text-muted" style="font-size: 0.9rem;">
                        <th class="fw-normal border-0 border-bottom pb-3">Đồ</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Danh mục</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Địa điểm</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Ngày nhặt</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Số ngày chưa nhận</th>
                        <th class="fw-normal border-0 border-bottom pb-3">Người báo</th>
                        <th class="fw-normal border-0 border-bottom pb-3 text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody style="font-size: 0.95rem;">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="py-3 border-bottom fw-medium text-dark">@item.Title</td>
                            <td class="py-3 border-bottom">@item.CategoryName</td>
                            <td class="py-3 border-bottom">@item.LocationName</td>
                            <td class="py-3 border-bottom text-muted" style="font-size: 0.9rem;">@item.FoundAt.ToString("MM/dd/yyyy")</td>
                            <td class="py-3 border-bottom">
                                <span class="badge @(item.DaysUnclaimed > 60 ? "bg-danger" : (item.DaysUnclaimed > 30 ? "bg-warning" : "bg-info"))" style="border-radius: 4px;">
                                    @item.DaysUnclaimed ngày
                                </span>
                            </td>
                            <td class="py-3 border-bottom">@item.ReporterName</td>
                            <td class="py-3 border-bottom text-end">
                                <form asp-action="DisposeItem" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn đánh dấu món này là đã thanh lý? Không hoàn tác được.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger px-3" style="border-radius: 6px; font-weight: 500;">Thanh lý</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>