@model List<LostAndFound.Models.ViewModels.Admin.LocationViewModel>
@{
    ViewData["Title"] = "Quản lý địa điểm";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1 text-dark">Quản lý địa điểm</h3>
            <p class="text-muted mb-0">Quản lý địa điểm trong trường</p>
        </div>
        <a asp-action="CreateLocation" class="btn btn-primary" style="border-radius: 6px;">
            <i class="bi bi-plus-lg me-1"></i> Thêm địa điểm
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 border-0" role="alert" style="background-color: #dcfce7; color: #166534; border-radius: 6px;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4 border-0" role="alert" style="background-color: #fee2e2; color: #991b1b; border-radius: 6px;">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table align-middle" style="border-top: 1px solid #e5e7eb;">
            <thead>
                <tr class="text-muted" style="font-size: 0.9rem;">
                    <th class="fw-normal border-0 border-bottom pb-3">Toà nhà</th>
                    <th class="fw-normal border-0 border-bottom pb-3">Tên địa điểm</th>
                    <th class="fw-normal border-0 border-bottom pb-3">Số đồ</th>
                    <th class="fw-normal border-0 border-bottom pb-3 text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody style="font-size: 0.95rem;">
                @foreach (var location in Model)
                {
                    <tr>
                        <td class="py-3 border-bottom">@location.Building ?? "-"</td>
                        <td class="py-3 border-bottom fw-medium text-dark">@location.Name</td>
                        <td class="py-3 border-bottom">
                            <span class="badge bg-secondary" style="border-radius: 4px;">@location.ItemCount</span>
                        </td>
                        <td class="py-3 border-bottom text-end">
                            <a asp-action="EditLocation" asp-route-id="@location.Id" class="btn btn-sm btn-outline-primary px-3 me-1" style="border-radius: 6px; font-weight: 500;">Sửa</a>
                            <form asp-action="DeleteLocation" asp-route-id="@location.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xoá địa điểm này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger px-3" style="border-radius: 6px; font-weight: 500;">Xoá</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>