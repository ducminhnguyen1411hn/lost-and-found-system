@model LostAndFound.Models.ViewModels.Admin.CategoryCreateViewModel
@{
    ViewData["Title"] = "Create Category";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm" style="border-radius: 8px;">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4 text-dark">Create New Category</h4>

                    <form asp-action="CreateCategory" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-medium">Category Name</label>
                            <input asp-for="Name" class="form-control" style="border-radius: 6px;" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ParentId" class="form-label fw-medium">Parent Category (Optional)</label>
                            <select asp-for="ParentId" class="form-select" style="border-radius: 6px;">
                                <option value="">-- None (Root Category) --</option>
                                @if (ViewBag.ParentCategories != null)
                                {
                                    @foreach (var parent in ViewBag.ParentCategories as List<LostAndFound.Models.ViewModels.Admin.CategoryViewModel>)
                                    {
                                        if (parent.ParentId == null) // Only show root categories as parents
                                        {
                                            <option value="@parent.Id">@parent.Name</option>
                                        }
                                    }
                                }
                            </select>
                            <span asp-validation-for="ParentId" class="text-danger small"></span>
                            <small class="text-muted">Leave empty for a root category</small>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary" style="border-radius: 6px;">Create Category</button>
                            <a asp-action="Categories" class="btn btn-outline-secondary" style="border-radius: 6px;">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}