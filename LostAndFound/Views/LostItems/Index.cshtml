@model LostItemSearchViewModel
@{
    ViewData["Title"] = "Đồ bị mất";
    var nowMax = AppTime.LocalNow.ToString("yyyy-MM-ddTHH:mm");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Đồ bị mất</h1>
    @if (User.Identity is not null && User.Identity.IsAuthenticated)
    {
        <a asp-action="Create" class="btn btn-primary">+ Đăng đồ bị mất</a>
    }
</div>

<form asp-action="Index" method="get" class="row g-2 align-items-end mb-4">
    <div class="col-md-4">
        <label class="form-label">Từ khoá</label>
        <input asp-for="Keyword" class="form-control" placeholder="Tiêu đề / mô tả..." />
    </div>
    <div class="col-md-4">
        <label class="form-label">Danh mục</label>
        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
            <option value="">-- Tất cả --</option>
        </select>
    </div>
    <div class="col-md-4">
        <label class="form-label">Khu vực</label>
        <select asp-for="LocationId" asp-items="Model.Locations" class="form-select">
            <option value="">-- Tất cả --</option>
        </select>
    </div>
    <div class="col-md-4">
        <label class="form-label">Thẻ</label>
        <input asp-for="Tag" class="form-control" placeholder="thẻ..." />
    </div>
    <div class="col-md-4">
        <label asp-for="LostFrom" class="form-label">Mất từ</label>
        <input asp-for="LostFrom" type="datetime-local" max="@nowMax" class="form-control" />
        <div class="form-text">Bỏ trống = từ sớm nhất.</div>
    </div>
    <div class="col-md-4">
        <label asp-for="LostTo" class="form-label">Đến</label>
        <input asp-for="LostTo" type="datetime-local" max="@nowMax" class="form-control" />
        <div class="form-text">Bỏ trống = đến hiện tại.</div>
        <span asp-validation-for="LostTo" class="text-danger"></span>
        <span asp-validation-for="LostFrom" class="text-danger"></span>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-outline-primary">Tìm kiếm</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Xoá lọc</a>
    </div>
</form>

@if (Model.Results.TotalCount == 0)
{
    <div class="alert alert-info">Không tìm thấy bài đăng nào phù hợp.</div>
}
else
{
    <p class="text-muted">Tìm thấy @Model.Results.TotalCount kết quả.</p>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
        @foreach (var item in Model.Results.Items)
        {
            <div class="col">
                <partial name="_LostItemCard" model="item" />
            </div>
        }
    </div>

    <div class="mt-4">
        <partial name="_LostPager" model="Model" />
    </div>
}
