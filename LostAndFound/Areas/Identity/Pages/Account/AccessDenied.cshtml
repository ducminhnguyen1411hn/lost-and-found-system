@page
@model LostAndFound.Areas.Identity.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access denied";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-10 col-lg-8">
            <h3 class="fw-bold mb-4 text-dark">Access denied</h3>

            <div class="alert mb-4" role="alert" style="background-color: #fef08a; color: #854d0e; border: none; border-radius: 6px; padding: 16px;">
                <strong>403</strong> — You don't have permission to view this page.
            </div>

            <p class="text-muted mb-4">
                [Authorize(Roles="Admin")] blocked this. Signed in as Member.
            </p>

            <a href="~/" class="btn btn-outline-primary px-4 py-2" style="border-radius: 6px; font-weight: 500;">
                Back to home
            </a>
        </div>
    </div>
</div>