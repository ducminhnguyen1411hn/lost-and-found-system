@page
@model LostAndFound.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-8 col-lg-7">
            <h3 class="fw-bold mb-4 text-dark">Create a new Member account</h3>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label class="form-label text-dark">Full name <span class="text-danger">*</span></label>
                    <input asp-for="Input.FullName" class="form-control" placeholder="Nguyen Van A" />
                    <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label text-dark">Student / staff code <span class="text-danger">*</span></label>
                        <input asp-for="Input.StudentOrStaffCode" class="form-control" placeholder="SV123456" />
                        <span asp-validation-for="Input.StudentOrStaffCode" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-dark">Faculty / department</label>
                        <input asp-for="Input.Department" class="form-control" placeholder="Faculty of IT" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label text-dark">Email <span class="text-danger">*</span></label>
                    <input asp-for="Input.Email" class="form-control" placeholder="nva@student.edu.vn" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label text-dark">Password <span class="text-danger">*</span></label>
                        <input asp-for="Input.Password" class="form-control" type="password" placeholder="........" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-dark">Confirm password</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" type="password" placeholder="........" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary px-4 py-2" style="background-color: #2563eb; border: none; border-radius: 6px;">Register</button>

                <p class="text-muted small mt-3" style="font-size: 0.85rem;">
                    On submit &rarr; account created, assigned the <strong>Member</strong> role, and signed in.
                </p>
            </form>
        </div>
    </div>
</div>